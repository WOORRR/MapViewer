{
  "version": 6,
  "cmakeMinimumRequired": {"major": 3, "minor": 25, "patch": 0},
  "configurePresets": [
    {
      "name": "msvc-x64-debug",
      "displayName": "MSVC x64 Debug (VS 18 2026)",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/debug",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release"
      }
    },
    {
      "name": "msvc-x64-release",
      "inherits": "msvc-x64-debug",
      "binaryDir": "${sourceDir}/build/release"
    }
  ],
  "buildPresets": [
    {"name": "msvc-x64-debug",   "configurePreset": "msvc-x64-debug",   "configuration": "Debug"},
    {"name": "msvc-x64-release", "configurePreset": "msvc-x64-release", "configuration": "Release"}
  ],
  "testPresets": [
    {"name": "msvc-x64-debug", "configurePreset": "msvc-x64-debug", "configuration": "Debug", "output": {"outputOnFailure": true}}
  ]
}
